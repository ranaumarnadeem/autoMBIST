# Auto-generated by autombist (test mode)
# Run from this directory: make

MODULE_DIR := $(abspath $(dir $(lastword $(MAKEFILE_LIST))))
PROJECT_ROOT := $(abspath $(MODULE_DIR)/../..)

MEMORY_NAME := {{ memory_name }}
WRAPPER_MODULE := {{ wrapper_module_name }}

USE_SABOTEUR := 1
FAULT_MODE := faults
FAULTS := {{ fault_count }}
{% if fault_seed is not none %}FAULT_SEED := {{ fault_seed }}
{% else %}FAULT_SEED :=
{% endif %}
SIM ?= icarus
PYTHON_BIN ?= $(PROJECT_ROOT)/venv/bin/python3
SIM_LOG ?= fault_sim.log

.PHONY: all fault-test debug precheck

all: fault-test

precheck:
	@if [ ! -x "$(PYTHON_BIN)" ]; then \
		echo "Python3 not found at $(PYTHON_BIN). Maybe use venv? or install Python3."; \
		exit 1; \
	fi

fault-test: precheck
	@echo "[autombist] Running fault simulation"
	@$(MAKE) -C $(PROJECT_ROOT)/tests/hardware SIM=$(SIM) \
		OUTDIR=$(PROJECT_ROOT)/out \
		MEMORY_NAME=$(MEMORY_NAME) \
		WRAPPER_MODULE=$(WRAPPER_MODULE) \
		USE_SABOTEUR=$(USE_SABOTEUR) \
		FAULT_MODE=$(FAULT_MODE) \
		FAULTS=$(FAULTS) \
		FAULT_SEED=$(FAULT_SEED) \
		PYTHON_BIN=$(PYTHON_BIN) > $(SIM_LOG) 2>&1 || (echo "[autombist] Simulation failed. Inspect $(SIM_LOG)"; grep -E "ERROR|FAIL|Traceback|AssertionError" $(SIM_LOG) || true; exit 1)
	@if grep -q "test_mbist.test_faults passed" $(SIM_LOG); then \
		echo "[autombist] Result: PASS"; \
		echo "[autombist] Fault count: $(FAULTS)"; \
		echo "[autombist] Seed: $(if $(FAULT_SEED),$(FAULT_SEED),random)"; \
		echo "[autombist] Log: $(SIM_LOG)"; \
		echo "[autombist] Use 'make debug' for full live output"; \
	else \
		echo "[autombist] Result: FAIL. Inspect $(SIM_LOG)"; \
		exit 1; \
	fi

debug: precheck
	@echo "[autombist] Running debug simulation"
	@$(MAKE) -C $(PROJECT_ROOT)/tests/hardware SIM=$(SIM) \
		OUTDIR=$(PROJECT_ROOT)/out \
		MEMORY_NAME=$(MEMORY_NAME) \
		WRAPPER_MODULE=$(WRAPPER_MODULE) \
		USE_SABOTEUR=$(USE_SABOTEUR) \
		FAULT_MODE=$(FAULT_MODE) \
		FAULTS=$(FAULTS) \
		FAULT_SEED=$(FAULT_SEED) \
		PYTHON_BIN=$(PYTHON_BIN) > $(SIM_LOG) 2>&1 || (echo "[autombist] Simulation failed. Showing last errors:"; grep -E "ERROR|FAIL|Traceback|AssertionError" $(SIM_LOG) || true; exit 1)
	@grep -vE "\*\* TESTS=|\*\* TEST\s+STATUS|\*\* test_mbist\.test_|\*{10,}" $(SIM_LOG)
	@if grep -q "test_mbist.test_faults passed" $(SIM_LOG); then \
		echo "[autombist] Debug summary: fault test PASS"; \
	else \
		echo "[autombist] Debug summary: fault test FAIL"; \
		exit 1; \
	fi
	@echo "[autombist] Full raw log: $(SIM_LOG)"
